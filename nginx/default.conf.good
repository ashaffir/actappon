worker_processes auto;
events {
    worker_connections 1024;
}

http {
    map $http_origin $cors_origin {
        default 0;
        "~https://www.albaniaconnect.com" $http_origin;
        "~https://albaniaconnect.com" $http_origin;
    }


    include /etc/nginx/mime.types;
    default_type application/octet-stream;
    
    sendfile on;
    keepalive_timeout 65;

    # Your server block goes here
    server {
        listen 80;
        server_name actappon.com;

        location /.well-known/acme-challenge/ {
            root /var/www/certbot;
        }

        location / {
            return 301 https://$host$request_uri;
        }
    }
   
    server {
        listen 443 ssl;
        server_name actappon.com;

	ssl_certificate /etc/letsencrypt/live/actappon.com/fullchain.pem;
    	ssl_certificate_key /etc/letsencrypt/live/actappon.com/privkey.pem;

        ssl_protocols TLSv1.2 TLSv1.3;
        ssl_prefer_server_ciphers on;
        ssl_ciphers "ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384";

        location / {
	        proxy_pass http://wordpress:80;
        	proxy_set_header Host $host;
	        proxy_set_header X-Real-IP $remote_addr;
        	proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
	        proxy_set_header X-Forwarded-Proto $scheme;
	
	        # Timeout settings
	        proxy_connect_timeout 60s;
        	proxy_send_timeout 60s;
	        proxy_read_timeout 120s;
	        send_timeout 120s;
        }
    }

    # Configuration for filebrowser.actappon.com
    server {
        listen 80;
        server_name filebrowser.actappon.com;
	
	client_max_body_size 100M;

        location /.well-known/acme-challenge/ {
            root /var/www/certbot;
        }

        location / {
            return 301 https://$host$request_uri;
        }
    }

    server {
        listen 443 ssl;
        server_name filebrowser.actappon.com;

	client_max_body_size 100M;

	ssl_certificate /etc/letsencrypt/live/actappon.com/fullchain.pem;
    	ssl_certificate_key /etc/letsencrypt/live/actappon.com/privkey.pem;

        ssl_protocols TLSv1.2 TLSv1.3;
        ssl_prefer_server_ciphers on;
        ssl_ciphers "ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384";

        location / {
                proxy_pass http://filebrowser:80;
                proxy_set_header Host $host;
                proxy_set_header X-Real-IP $remote_addr;
                proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
                proxy_set_header X-Forwarded-Proto $scheme;

	
	        # Timeout settings
	        proxy_connect_timeout 60s;
        	proxy_send_timeout 60s;
	        proxy_read_timeout 120s;
	        send_timeout 120s;
        }
    }

    # Configuration for monitor.actappon.com
    server {
        listen 80;
        server_name monitor.actappon.com;
	
	client_max_body_size 100M;

        location /.well-known/acme-challenge/ {
            root /var/www/certbot;
        }

        location / {
            return 301 https://$host$request_uri;
        }
    }

    server {
        listen 443 ssl;
        server_name monitor.actappon.com;

	client_max_body_size 100M;

	ssl_certificate /etc/letsencrypt/live/actappon.com/fullchain.pem;
    	ssl_certificate_key /etc/letsencrypt/live/actappon.com/privkey.pem;

        ssl_protocols TLSv1.2 TLSv1.3;
        ssl_prefer_server_ciphers on;
        ssl_ciphers "ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384";

        location / {
                proxy_pass http://monitor:3001;
                proxy_set_header Host $host;
                proxy_set_header X-Real-IP $remote_addr;
                proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
                proxy_set_header X-Forwarded-Proto $scheme;

	
	        # Timeout settings
	        proxy_connect_timeout 60s;
        	proxy_send_timeout 60s;
	        proxy_read_timeout 120s;
	        send_timeout 120s;
        }
    }

	# Configuration for trader.actappon.com
	server {
	    listen 80;
	    server_name trader.actappon.com;

	    location /.well-known/acme-challenge/ {
		root /var/www/certbot;
	    }

	    location / {
		return 301 https://$host$request_uri;
	    }
	}

	server {
	    listen 443 ssl;
	    server_name trader.actappon.com;

	    ssl_certificate /etc/letsencrypt/live/actappon.com/fullchain.pem;
	    ssl_certificate_key /etc/letsencrypt/live/actappon.com/privkey.pem;

	    ssl_protocols TLSv1.2 TLSv1.3;
	    ssl_prefer_server_ciphers on;
	    ssl_ciphers "ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384";

	    location / {
		proxy_pass http://172.20.0.1:8800;
		proxy_set_header Host $host;
		proxy_set_header X-Real-IP $remote_addr;
		proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
		proxy_set_header X-Forwarded-Proto $scheme;
	    }
	}

        # Configuration for crypto-trader.actappon.com
        server {
            listen 80;
            server_name crypto-trader.actappon.com;

            location /.well-known/acme-challenge/ {
                root /var/www/certbot;
            }

            location / {
                return 301 https://$host$request_uri;
            }
        }

        server {
            listen 443 ssl;
            server_name crypto-trader.actappon.com;

            ssl_certificate /etc/letsencrypt/live/actappon.com/fullchain.pem;
            ssl_certificate_key /etc/letsencrypt/live/actappon.com/privkey.pem;

            ssl_protocols TLSv1.2 TLSv1.3;
            ssl_prefer_server_ciphers on;
            ssl_ciphers "ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384";
	
	location / {
	    proxy_pass http://172.20.0.1:8501;
	    proxy_http_version 1.1;

	    # Required for Streamlit's WebSocket + event streaming
	    proxy_set_header Upgrade $http_upgrade;
	    proxy_set_header Connection "upgrade";

	    # Preserve host and real IP
	    proxy_set_header Host $host;
	    proxy_set_header X-Real-IP $remote_addr;
	    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
	    proxy_set_header X-Forwarded-Proto $scheme;

	    # Prevent premature timeouts
	    proxy_read_timeout 86400;
	}

       }


	server {
	    listen 443 ssl;
	    http2 on;

	    server_name llm.actappon.com;

	    ssl_certificate /etc/letsencrypt/live/llm.actappon.com/fullchain.pem;
	    ssl_certificate_key /etc/letsencrypt/live/llm.actappon.com/privkey.pem;

            #ssl_certificate /etc/letsencrypt/live/actappon.com/fullchain.pem;
            #ssl_certificate_key /etc/letsencrypt/live/actappon.com/privkey.pem;

            ssl_protocols TLSv1.2 TLSv1.3;
            ssl_prefer_server_ciphers on;
            ssl_ciphers "ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384";

	    location / {
		proxy_pass http://10.100.102.121:8080;
		proxy_http_version 1.1;
		proxy_set_header Host $host;
		proxy_set_header X-Real-IP $remote_addr;
		proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
		proxy_set_header Upgrade $http_upgrade;
		proxy_set_header Connection "upgrade";
		proxy_read_timeout 3600s;
	    }

	    # Optional basic authentication
	    #auth_basic "Restricted Access";
	    #auth_basic_user_file /etc/nginx/.htpasswd;
	}

	server {
	    listen 80;
	    server_name iocane.ai www.iocane.ai;

	    location /.well-known/acme-challenge/ {
		root /var/www/certbot;
	    }

	    location / {
		return 301 https://$host$request_uri;
	    }
	}

	server {
	    listen 443 ssl;
	    server_name iocane.ai www.iocane.ai;

	    ssl_certificate /etc/letsencrypt/live/iocane.ai/fullchain.pem;
	    ssl_certificate_key /etc/letsencrypt/live/iocane.ai/privkey.pem;

	    ssl_protocols TLSv1.2 TLSv1.3;
	    ssl_prefer_server_ciphers on;
	    ssl_ciphers "ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384";

	    client_max_body_size 100M;

	    location / {
		proxy_pass http://website:3000;
		
		proxy_http_version 1.1;

		proxy_set_header Host $host;
		proxy_set_header X-Real-IP $remote_addr;
		proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
		proxy_set_header X-Forwarded-Proto $scheme;

		proxy_set_header Upgrade $http_upgrade;
		proxy_set_header Connection "upgrade";

		proxy_connect_timeout 60s;
		proxy_send_timeout 60s;
		proxy_read_timeout 120s;
		send_timeout 120s;
	    }
	}

	server {
	    listen 80;
	    server_name api.iocane.ai;

	    location /.well-known/acme-challenge/ {
		root /var/www/certbot;
	    }

	    location / {
		return 301 https://$host$request_uri;
	    }
	}

	server {
	    listen 443 ssl;
	    server_name api.iocane.ai;


	    ssl_certificate /etc/letsencrypt/live/iocane.ai/fullchain.pem;
	    ssl_certificate_key /etc/letsencrypt/live/iocane.ai/privkey.pem;

	    ssl_protocols TLSv1.2 TLSv1.3;
	    ssl_prefer_server_ciphers on;
	    ssl_ciphers "ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384";

	    client_max_body_size 100M;


	    # Route OTLP Traces to Collector
	    location /v1/traces {
		proxy_pass http://collector:8001;

		proxy_http_version 1.1;

		proxy_set_header Host $host;
		proxy_set_header X-Real-IP $remote_addr;
		proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
		proxy_set_header X-Forwarded-Proto $scheme;

		proxy_set_header Upgrade $http_upgrade;
		proxy_set_header Connection "upgrade";

		proxy_connect_timeout 60s;
		proxy_send_timeout 60s;
		proxy_read_timeout 120s;
		send_timeout 120s;
	    }

	    location / {
		proxy_pass http://api:8000;

		proxy_http_version 1.1;

		proxy_set_header Host $host;
		proxy_set_header X-Real-IP $remote_addr;
		proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
		proxy_set_header X-Forwarded-Proto $scheme;

		proxy_set_header Upgrade $http_upgrade;
		proxy_set_header Connection "upgrade";

		proxy_connect_timeout 60s;
		proxy_send_timeout 60s;
		proxy_read_timeout 120s;
		send_timeout 120s;
	    }
	}

	server {
	    listen 80;
	    server_name dashboard.iocane.ai;

	    location /.well-known/acme-challenge/ {
		root /var/www/certbot;
	    }

	    location / {
		return 301 https://$host$request_uri;
	    }
	}

	server {
	    listen 443 ssl;
	    server_name dashboard.iocane.ai;

	    ssl_certificate /etc/letsencrypt/live/iocane.ai/fullchain.pem;
	    ssl_certificate_key /etc/letsencrypt/live/iocane.ai/privkey.pem;

	    ssl_protocols TLSv1.2 TLSv1.3;
	    ssl_prefer_server_ciphers on;
	    ssl_ciphers "ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384";

	    client_max_body_size 100M;

	    location / {
		proxy_pass http://dashboard:3000;

		proxy_http_version 1.1;

		proxy_set_header Host $host;
		proxy_set_header X-Real-IP $remote_addr;
		proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
		proxy_set_header X-Forwarded-Proto $scheme;

		proxy_set_header Upgrade $http_upgrade;
		proxy_set_header Connection "upgrade";

		proxy_connect_timeout 60s;
		proxy_send_timeout 60s;
		proxy_read_timeout 120s;
		send_timeout 120s;
	    }
	}

}

